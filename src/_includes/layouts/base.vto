<!doctype html>

<html lang="{{ it.lang }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ if it.title }} {{ it.title }} {{ else }} {{ metas.site }} {{ /if }}</title>
    <meta name="description" content="{{ it.description || metas.description }}">
    <meta property="og:type" content="{{ if it.type == 'post' }}article{{ else }}website{{ /if }}">
    <meta property="og:site_name" content="{{ metas.site }}">
    <meta property="og:locale" content="{{ metas.lang || it.lang }}">
    <meta property="og:title" content="{{ it.title || metas.site }}">
    <meta property="og:description" content="{{ it.description || metas.description }}">
    <meta property="og:url" content="{{ url |> url(true) }}">
    <meta property="og:image" content="{{ (it.image || metas.image || '/favicon.png') |> url(true) }}">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ it.title || metas.site }}">
    <meta name="twitter:description" content="{{ it.description || metas.description }}">
    <meta name="twitter:image" content="{{ (it.image || metas.image || '/favicon.png') |> url(true) }}">
    <script>
      (() => {
        const saved = localStorage.getItem("theme");
        if (saved === "dark" || saved === "light") {
          document.documentElement.setAttribute("data-theme", saved);
        }
      })();
    </script>
    
    <link rel="stylesheet" href="/styles.css">
    <link rel="alternate" href="/feed.xml" type="application/atom+xml" title="{{ metas.site }}">
    <link rel="alternate" href="/feed.json" type="application/json" title="{{ metas.site }}">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png">
    <link rel="canonical" href="{{ url |> url(true) }}">
    <script src="/js/main.js" type="module"></script>
    {{ it.extra_head?.join("\n") }}
  </head>
  <body>
    <nav class="navbar">
      <a href="/" class="navbar-home">
        {{ if it.logo }}
          {{ it.logo }}
        {{ else }}
          <strong>{{ metas.site }}</strong>
        {{ /if }}
      </a>

      <ul class="navbar-links">
      {{- for link of it.menu_links }}
        <li>
          <a href="{{ link.href }}"{{ if link.target }} target="{{link.target}}"{{ /if }}>
            {{ if link.img }}
              <img src="{{ link.img.icon |> icon(link.img.source) }}">
            {{ else }}
              {{ link.text }}
            {{ /if }}
          </a>
        </li>
      {{ /for }}
        <li>
          <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle theme" title="Toggle theme">
            <span class="theme-toggle-icon" aria-hidden="true"></span>
          </button>
        </li>
        <li class="burger">
          <button id="burger-toggle" class="burger-toggle" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="burger-menu">
            <span class="burger-lines" aria-hidden="true"></span>
          </button>
          <div id="burger-menu" class="burger-menu" role="menu" aria-hidden="true">
            <ul class="burger-menu-links">
              {{ for link of (it.burger_links || []) }}
                <li>
                  <a href="{{ link.href }}" {{ if link.href == url }} aria-current="page"{{ /if }} {{ if link.target }} target="{{ link.target }}"{{ /if }} role="menuitem">
                    {{ link.text }}
                  </a>
                </li>
              {{ /for }}
            </ul>
            {{ if (it.burger_footer_links || []).length }}
              <ul class="burger-menu-footer">
                {{ for link of (it.burger_footer_links || []) }}
                  <li>
                    <a href="{{ link.href }}" {{ if link.target }} target="{{ link.target }}"{{ /if }} role="menuitem">
                      {{ link.text }}
                    </a>
                  </li>
                {{ /for }}
              </ul>
            {{ /if }}
          </div>
        </li>
      </ul>
    </nav>

    <main class="{{ it.bodyClass }}">
      {{ content }}
    </main>
    <footer class="site-footer">
      <a class="footer-rss" href="/feed.xml" target="_blank" rel="noopener noreferrer" aria-label="RSS">
        <img src="{{ 'rss' |> icon('feather') }}" alt="rss">
      </a>
    </footer>
  </body>
</html>
